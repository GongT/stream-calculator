{
	// See https://go.microsoft.com/fwlink/?LinkId=733558
	// for the documentation about the tasks.json format
	"version": "2.0.0",
	"tasks": [
		{
			"label": "监视并启动",
			"icon": {
				"id": "play-circle",
				"color": "terminal.ansiGreen",
			},
			"dependsOn": ["启动", "监视"],
			"presentation": {
				"group": "build",
			},
		},
		{
			"label": "启动",
			"type": "process",
			"command": "pnpm",
			"hide": true,
			"args": ["--silent", "start"],
			"group": "build",
			"icon": {
				"id": "play",
				"color": "terminal.ansiGreen",
			},
			"runOptions": { "instancePolicy": "silent" },
			"presentation": {
				"reveal": "always",
				"panel": "shared",
				"group": "build",
			},
		},
		{
			"label": "监视",
			"type": "process",
			"command": "pnpm",
			"hide": true,
			"args": ["--silent", "watch"],
			"group": "build",
			"icon": {
				"id": "play",
				"color": "terminal.ansiGreen",
			},
			"runOptions": { "instancePolicy": "silent" },
			"presentation": {
				"reveal": "never",
				"panel": "shared",
				"group": "build",
				"clear": false,
			},
		},
	],
}
